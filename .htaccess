# Adobe Ingeniería — Apache .htaccess
# Caché, compresión, HTTPS y errores personalizados

# ── HTTPS forzado ──────────────────────────────────────────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── www → sin www (elegir una versión canónica) ───────────────────────────
# Descomentar la línea deseada:
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# ── Bloquear listado de directorios ───────────────────────────────────────
Options -Indexes

# ── Compresión Gzip ────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
  AddOutputFilterByType DEFLATE application/json image/svg+xml
</IfModule>

# ── Caché del navegador ────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                "access plus 0 seconds"
  ExpiresByType text/css                 "access plus 1 year"
  ExpiresByType application/javascript   "access plus 1 year"
  ExpiresByType image/jpeg               "access plus 1 week"
  ExpiresByType image/png                "access plus 1 week"
  ExpiresByType image/svg+xml            "access plus 1 year"
  ExpiresByType image/x-icon             "access plus 1 year"
  ExpiresByType video/mp4                "access plus 1 month"
  ExpiresByType application/manifest+json "access plus 1 week"
</IfModule>

# ── Página de error personalizada ─────────────────────────────────────────
ErrorDocument 404 /404.html
ErrorDocument 500 /404.html

# ── Seguridad HTTP headers ─────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Anti-clickjacking
  Header always set X-Frame-Options "DENY"
  # Evitar MIME sniffing
  Header always set X-Content-Type-Options "nosniff"
  # XSS filter legacy browsers
  Header always set X-XSS-Protection "1; mode=block"
  # Referrer controlado
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Permisos de APIs del navegador
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  # HSTS: forzar HTTPS por 1 año en todos los subdominios
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # Content Security Policy: solo recursos propios + Google Fonts + WhatsApp
  Header always set Content-Security-Policy "default-src 'self'; \
    script-src 'self' 'unsafe-inline'; \
    style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; \
    font-src 'self' https://fonts.gstatic.com; \
    img-src 'self' data: https:; \
    media-src 'self'; \
    connect-src 'self'; \
    frame-ancestors 'none';"
</IfModule>

# ── Ocultar versión del servidor ───────────────────────────────────────────
ServerSignature Off
